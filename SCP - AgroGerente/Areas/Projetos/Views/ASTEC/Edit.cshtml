@model SCP___AgroGerente.Areas.Projetos.Model.CadastroASTEC

@{
    ViewBag.Title = "Edit";
    Layout = "~/Areas/Projetos/Views/Shared/_Layout.cshtml";
}


<div class="Cabecalho">
    <div class="left">
        <h2>Criar ASTEC</h2>

    </div>
    <div class="right">
        <a href="javascript:window.history.back();" class="icone Goback" title="Voltar">Voltar para a lista</a>
    </div>
    <div class="clear"></div>

</div>
<br />


@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()
    @Html.HiddenFor(model => model.ID)

    <div class="form-horizontal">
        <div class="box">
            @Html.ValidationSummary(true, "", new { @class = "text-danger" })
            <div class="form-group">
                @Html.LabelFor(model => model.AstecSafra, "Safra", htmlAttributes: new { @class = "control-label col-md-2" })
                <div class="col-md-10">
                    @Html.DropDownList("AstecSafra", null, htmlAttributes: new { @class = "form-control" })
                    @Html.ValidationMessageFor(model => model.AstecSafra, "", new { @class = "text-danger" })
                </div>
            </div>

        </div>


        <div class="form-group">
            @Html.LabelFor(model => model.AstecValor, "ASTEC (%)", htmlAttributes: new { @class = "control-label col-md-2" })
            <div class="col-md-10">
                @Html.EditorFor(model => model.AstecValor, new { htmlAttributes = new { @class = "form-control" } })
                @Html.ValidationMessageFor(model => model.AstecValor, "", new { @class = "text-danger" })
            </div>
        </div>

        <div class="form-group">
            <div class="col-md-offset-2 col-md-10">
                <input type="submit" value="Criar ASTEC" class="btn btn-default" />
            </div>
        </div>
    </div>
}



@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}

