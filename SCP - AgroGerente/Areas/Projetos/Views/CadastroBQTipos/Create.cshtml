@model SCP___AgroGerente.Areas.Projetos.Model.CadastroBQTipo

@{
    ViewBag.Title = "Create";
    Layout = "~/Areas/Projetos/Views/Shared/_Layout.cshtml";
}

<div class="Cabecalho">
    <div class="left">
        <h2>Criar Tipo de Pergunta</h2>

    </div>
    <div class="right">
        <a href="javascript:window.history.back();" class="icone Goback" title="Voltar">Voltar para a lista</a>
    </div>
    <div class="clear"></div>

</div>
<br />


@using (Html.BeginForm()) 
{
    @Html.AntiForgeryToken()
    
    <div class="form-horizontal">
        @Html.ValidationSummary(true, "", new { @class = "text-danger" })
        <div class="box">
            <div class="left">

                <div class="form-group">
                    @Html.LabelFor(model => model.BQTipoAtivo,"Ativo?", htmlAttributes: new { @class = "control-label col-md-2" })
                    <div class="col-md-10">
                        <div class="checkbox">
                            <input class="check-box" checked="checked" data-val="true" data-val-required="O campo BQTipoAtivo é obrigatório." id="BQTipoAtivo" name="BQTipoAtivo" type="checkbox" value="true">
                            Sim
                            @Html.ValidationMessageFor(model => model.BQTipoAtivo, "", new { @class = "text-danger" })
                        </div>
                    </div>
                </div>
            </div>
            <div class="left" style="padding-left:20px">
                <div class="form-group">
                    @Html.LabelFor(model => model.BQTipo, "Descrição do tipo", htmlAttributes: new { @class = "control-label col-md-2" })
                    <div class="col-md-10">
                        @Html.EditorFor(model => model.BQTipo, new { htmlAttributes = new { @class = "form-control", @style="width:300px" } })
                        @Html.ValidationMessageFor(model => model.BQTipo, "", new { @class = "text-danger" })
                    </div>
                </div>
            </div>
            <div class="clear"></div>
        </div>
           <br />

            <div class="form-group">
                <div class="col-md-offset-2 col-md-10">
                    <input type="submit" value="Criar Tipo de Pergunta" class="btn btn-default" />
                </div>
            </div>
        </div>
}


@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
