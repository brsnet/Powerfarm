                <script>var rt32 = "0";</script>
                <script>                var showareaid = "0";</script><a href="#loginbox"></a>

                <center>
                    <div id="map_canvas" style="width: 98%; height: 600px"></div>


                    <h2>Options</h2>
                    <div align="center">
                        <input type="button" value="Delete Last Point" onclick="DeleteLastPoint();" class="custombutton" />
                        <input type="button" value="Clear All Points" onclick="ClearAllPoints();" class="custombutton" />
                        <input type="button" name="btn_genkml" id="btn_genkml" value="Generate KML" onclick="genkml();" class="custombutton" />
                        <input type="button" name="btn_newarea" id="btn_newarea" value="Create New Area" onclick="newarea();" class="custombutton" />
                        <input type="button" name="btn_zoomtofit" id="btn_zoomtofit" value="Zoom To Fit" onclick="ftn_zoomtofit();" class="custombutton" />
                    </div>
                    <div align="center">
                        <p>
                            [Map Height : <a href="javascript:void(0)" onclick="javascript:document.getElementById('map_canvas').style.height='400px';google.maps.event.trigger(map, 'resize');">Small</a> - <a href="javascript:void(0)" onclick="javascript:document.getElementById('map_canvas').style.height='600px';google.maps.event.trigger(map, 'resize');">Medium</a> -
                            <a href="javascript:void(0)" onclick="javascript:document.getElementById('map_canvas').style.height='800px';google.maps.event.trigger(map, 'resize');">Large</a> -
                            <a href="javascript:void(0)" onclick="fsmap();">Full Screen</a>]
                        </p>
                    </div>
                </center>
                <div id="contenttext">
                    <div align="center">
                        <div id="div_outputkml" style="visibility:hidden;"></div>
                        <h2>Output : Current Area</h2>

                        <div align="center" id="area">0 m&sup2;</div>
                        <div align="center" id="areakm">0 km&sup2;</div>
                        <div align="center" id="areaacre">0 acres</div>
                        <div align="center" id="areahectare">0 hectares</div>
                        <div align="center" id="areafeet">0 feet&sup2;</div>
                        <div align="center" id="sqnautmiles">0 square nautical miles</div>

                        <div align="center" id="div_currentperim"></div>

                        <div id="div_totalareas" style="visibility:hidden;">
                            <h2>Output : Total Area(s)</h2>
                            <div align="center" id="totalarea">0 m&sup2;</div>
                            <div align="center" id="totalareakm">0 km&sup2;</div>
                            <div align="center" id="totalareaacre">0 acres</div>
                            <div align="center" id="totalareahectare">0 hectares</div>
                            <div align="center" id="totalareafeet">0 feet&sup2;</div>
                            <div align="center" id="totalsqnautmiles">0 square nautical miles</div>
                        </div>
                    </div>

