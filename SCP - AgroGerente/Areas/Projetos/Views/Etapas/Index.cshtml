@model IEnumerable<SCP___AgroGerente.Areas.Projetos.Model.CadastroEtapa>

@{
    ViewBag.Title = "Lista de Etapas";
    Layout = "~/Areas/Projetos/Views/Shared/_Layout.cshtml";
}

<div class="Cabecalho">
    <div class="left">
        <h2>Lista de Etapas</h2>

    </div>
    <div class="right">
        @Html.ActionLink("Novo Cadastro", "Create", string.Empty, new { @class = "icone new" })
    </div>
    <div class="clear"></div>

</div>
<br />

@{
    WebGrid grid = new WebGrid(Model);
}

@grid.GetHtml(tableStyle: "tabelaFormatada", columns: new[] {
    grid.Column("EtapaAtiva", header:" Ativa?",style:"width1 alignCenter",format:@<text>

@if (item.EtapaAtiva==true)
	{
		 <text>Sim</text>
	} else
	{
         <text>Não</text>
	}



</text>),
   
     grid.Column("EtapaOrdem", header:" Ordenação", style:"width2 alignCenter"), 
      grid.Column("EtapaNome", header:" Nome da Etapa"),
     grid.Column("",header:"Ações", format:@<text>

        @Html.ActionLink(" ", "Edit", new { id = item.ID }, new { @class = "icone edit" })
        @Ajax.ActionLink(" ", "Delete", new { id = item.ID }, new AjaxOptions { HttpMethod = "POST", Confirm = "Deseja mesmo deletar?", OnSuccess = "window.location.reload()" }, new { @class = "icone delete" })


    </text>)


})

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}






