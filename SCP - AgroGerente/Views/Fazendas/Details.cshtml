            @Html.LabelFor(model => model.FazendaRoteiroAcesso, "Roteiro de acesso")
        </div>
        <div class="editor-field">
            @Html.DisplayFor(model => model.FazendaRoteiroAcesso)
        </div>
  </div>
        <div class="clear"></div>

        <h3>Confrotaçãoes</h3>
        <br />

         
        <div class="left">

        <div class="editor-label">
            @Html.LabelFor(model => model.FazendaConfrontacoesNorte, "Norte")
