                                        <td class="alignRight" colspan="2">@string.Format("{0:C}", totalBemDireito)</td>
                                    </tr>




                                    <tr class="totalsDoubleBorder">
                                        <td class="alignRight" colspan="3"> @string.Format("{0:C}", (totalTerraSolo + TotalBenfeitorias + (totalMaquina * porcentagemGeral / 100) + (totalVeiculo * porcentagemGeral / 100) + (totalImplemento * porcentagemGeral / 100) + TotalSemoventes + totalBemDireito))</td>
                                    </tr>


                                    <tr><td colspan="3" class="spacerBlank1"></td></tr>
                                    <tr>
                                        <td colspan="3" class="title soft">5 - IMÓVEIS ARRENDADOS</td>
                                    </tr>
                                    <tr><td colspan="3" class="spacerBlank1"></td></tr>

                                    <tr class="doubleBorderTitle">
                                        <td>Especificação</td>
                                        <td class="alignRight">Valor dos Imóveis</td>
                                        <td class="alignRight">Valor Arrendado</td>

                                    </tr>

                                    @{
                                        linesplus = 6;
                                    }

                                    @foreach (var item in ViewBag.TotaisFazendasArrendadas)
                                    {
                                        linesplus = linesplus - 1;
                                        TotalArrendadas = TotalArrendadas + ((Convert.ToDouble(item.Campo6)) + (Convert.ToDouble(item.Campo22)) + (Convert.ToDouble(item.Campo23)));

                                        if (item.Campo24 != "")
                                        {

                                            ValorArrendamento = Convert.ToDouble(item.Campo24);
                                            TotalArrendamento = TotalArrendamento + ValorArrendamento;



                                        }



                                        <tr class="">
                                            <td>@item.Campo1</td>
                                            <td class="alignRight">@string.Format("{0:C}", (Convert.ToDouble(item.Campo6)) + (Convert.ToDouble(item.Campo22)) + (Convert.ToDouble(item.Campo23)))</td>
                                            <td class="alignRight">@string.Format("{0:C}", ValorArrendamento)</td>
                                        </tr>
                                    }
                                    @for (int i = 0; i < linesplus; i++)
                                    {
                                        <tr class="">
                                            <td>-</td>
                                            <td class="alignRight">-</td>
                                            <td class="alignRight">-</td>
                                        </tr>
                                    }













                                    <tr class="totalsDoubleBorder">
                                        <td class="alignRight"> </td>
                                        <td class="alignRight"> @string.Format("{0:C}", TotalArrendadas)</td>
                                        <td class="alignRight"> @string.Format("{0:C}", TotalArrendamento)</td>

                                    </tr>

                                </table>




                            </td>
                        </tr>


                    </tbody>

                </table>

                <div class="printHidden">
                    <br />
                    <br />
                    <br />
                    <hr />
                    <br />
                    <br />
                    <br />
                </div>

                @*Dívidas*@
                <table class="PrinterTable"></table>

                <table class="PrinterTable">

                    <thead>
                        <tr>
                            <td colspan="2" class="title alignCenter" style="height:20px">DÍVIDAS</td>
                        </tr>
                        <tr><td colspan="2" class="spacerBlank2"></td></tr>
                        <tr>
                            <td colspan="2" class="title soft alignCenter">@Usuario</td>
                        </tr>
                        <tr><td colspan="2" class="spacerBlank2"></td></tr>
                        <tr>
                            <td colspan="2" class="title soft alignCenter">DÍVIDAS COM OUTROS AGENTES</td>
                        </tr>
                        <tr><td colspan="2" class="spacerBlank1"></td></tr>

                    </thead>

                    <tbody>

                        <tr>
                            <td colspan="2" style="vertical-align:top !important; height:820px">


                                <table class="doubleBorders">


                                    <tr class="doubleBorderTitle">
                                        <td class="alignCenter">Credor</td>
                                        <td class="alignCenter">Finalidade</td>
                                        <td class="alignCenter">Data<br />Contrat.</td>
                                        <td class="alignCenter">Data<br />Venc.</td>
                                        <td class="alignCenter">Carência</td>
                                        <td class="alignCenter">Encargos</td>
                                        <td class="alignCenter">Periodicidade</td>
                                        <td class="alignCenter">Saldo</td>

                                    </tr>
                                    @{
                                        linesplus = 20;
                                    }
                                    @foreach (var item in ViewBag.Dividas)
                                    {

                                        if (item != null)
                                        {

                                            TotalDivida = TotalDivida + (Convert.ToDouble(item.Campo8));
                                            linesplus = linesplus - 1;

                                        <tr class="">
                                            <td>@item.Campo1</td>
                                            <td>@item.Campo2</td>
                                            <td class="alignCenter">@item.Campo3</td>
                                            <td class="alignCenter">@item.Campo4</td>
                                            <td>@item.Campo5</td>
                                            <td>@item.Campo6</td>
                                            <td class="alignCenter">@item.Campo7</td>
                                            <td class="alignRight">@string.Format("{0:C}", (Convert.ToDouble(item.Campo8)))</td>

                                        </tr>
                                        }
                                        else
                                        {
                                            TotalDivida = 0;

                                        }


                                    }

                                    @for (int i = 0; i < linesplus; i++)
                                    {
                                        <tr class="">
                                            <td>-</td>
                                            <td>-</td>
                                            <td>-</td>
                                            <td>-</td>
                                            <td>-</td>
                                            <td>-</td>
                                            <td>-</td>
                                            <td>-</td>

                                        </tr>
                                    }



                                    <tr class="totalsDoubleBorder">
                                        <td class="alignRight" colspan="8"> @string.Format("{0:C}", TotalDivida)</td>
                                    </tr>
                                    <tr><td colspan="8" class="spacerBlank2"></td></tr>
                                    <tr>
                                        <td colspan="8" class="title alignCenter" style="height:20px">@string.Format("{0:C}", TotalDivida)</td>
                                    </tr>
                                    <tr><td colspan="8" class="spacerBlank2"></td></tr>
                                    <tr>
                                        <td colspan="8">

                                            Obs.: O proponente tem responsabilidade sobre @porcentagemGeral% destas dívidas, sendo que os outros @string.Format("{0:0.00}%", 100 - porcentagemGeral) são de responsabilidade de @Socios.

                                        </td>
                                    </tr>


                                </table>



                            </td>
                        </tr>


                    </tbody>

                </table>

            </td>
        </tr>
    </tbody>


</table>
