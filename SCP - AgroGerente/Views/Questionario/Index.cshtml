@model IEnumerable<SCP___AgroGerente.Models.CadastroQuestionario>

@{
    ViewBag.Title = "Index";
}

<div class="Cabecalho">
    <div class="left">
        <h2>Questionário</h2>
    </div>
    <div class="right">

        @Html.ActionLink("Novo Cadastro", "Create", string.Empty, new { @class = "icone new" })

    </div>
    <div class="clear"></div>
</div>
<br />
<table class="tabelaFormatada">
    <tr>
        <th>
            Questão
        </th>
        <th>
            Resposta 1
        </th>
        <th>
           Resposta 2
        </th>
        <th>
            Resposta 3
        </th>
        <th>
            Resposta 4
        </th>
        <th>
            Resposta 5
        </th>
        <th></th>
    </tr>

@foreach (var item in Model) {
    <tr>
        <td>
            @Html.DisplayFor(modelItem => item.QuestionarioQuestao)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.QuestionarioResposta1)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.QuestionarioResposta2)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.QuestionarioResposta3)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.QuestionarioResposta4)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.QuestionarioResposta5)
        </td>
        <td>
            @Html.ActionLink(" ", "Edit", new { id=item.ID }, new {@class = "icone edit" })
            @Ajax.ActionLink(" ", "Delete", new { id = item.ID }, new AjaxOptions { HttpMethod = "POST", Confirm = "Deseja mesmo deletar?", OnSuccess = "window.location.reload()" }, new { @class = "icone delete" })
        </td>
    </tr>
}

</table>
@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
