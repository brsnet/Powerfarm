@model SCP___AgroGerente.Models.CadastroUsuarios

@{
    ViewBag.Title = "Details";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>Detalhes do usuário: @Html.Raw(Model.Nome)</h2>
<p>
    @Html.ActionLink(" ", "Edit", new { id=Model.ID }, new {@class = "icone edit" })
    <a href="javascript:window.history.back();" class="icone Goback" title="Voltar"></a>
</p>
 <fieldset class="presentation">
        <legend>Cadastro de usuários</legend>   

        @Html.HiddenFor(model => model.ID)
<div class="box">
        <div class="left">

            <div class="editor-label">
                @Html.LabelFor(model => model.Nome)
            </div>
            <div class="editor-field">
                @Html.DisplayFor(model => model.Nome)
            </div>
        </div>
        <div class="left">
            <div class="editor-label">
                <label>Data de nascimento</label>
            </div>
            <div class="editor-field">
                @Html.DisplayFor(model => model.DataNascimento)
            </div>
        </div>
        <div class="left">
            <div class="editor-label">
                @Html.LabelFor(model => model.Naturalidade)
            </div>
            <div class="editor-field">
                @Html.DisplayFor(model => model.Naturalidade)
            </div>
        </div>
     <div class="left">
            <div class="editor-label">
                @Html.LabelFor(model => model.RendaMensal,"Renda mensal")
            </div>
            <div class="editor-field">
                @Html.DisplayFor(model => model.RendaMensal)
            </div>
       </div>
        <div class="clear"></div>
    </div>
        
        <h3>Documentos</h3>
        <br />
        <div class="left">
            <div class="editor-label">
                @Html.LabelFor(model => model.RG)
            </div>
            <div class="editor-field">
                @Html.DisplayFor(model => model.RG)
            </div>
        </div>
        <div class="left">
            <div class="editor-label">
                @Html.LabelFor(model => model.DataExpedicao, "Data de expedição")
            </div>
            <div class="editor-field">
                @Html.DisplayFor(model => model.DataExpedicao)
            </div>
        </div>
        <div class="left">
            <div class="editor-label">
                @Html.LabelFor(model => model.CPF)
            </div>
            <div class="editor-field">
                @Html.DisplayFor(model => model.CPF)
            </div>
        </div>
        
        <div class="clear"></div>
        <hr />
        <h3>Dados de contato</h3>
        <br />
        <div class="left">
            <div class="editor-label">
                @Html.LabelFor(model => model.Telefone1, "Telefone fixo principal")
            </div>
            <div class="editor-field">
                @Html.DisplayFor(model => model.Telefone1)
            </div>
        </div>
        <div class="left">
            <div class="editor-label">
                @Html.LabelFor(model => model.Telefone2, "Outro telefone")
            </div>
            <div class="editor-field">
                @Html.DisplayFor(model => model.Telefone2)
            </div>
        </div>
        <div class="left">
            <div class="editor-label">
                @Html.LabelFor(model => model.Celular1,"Celular do cliente")
            </div>
            <div class="editor-field">
                @Html.DisplayFor(model => model.Celular1)
            </div>
        </div>
        <div class="left">
            <div class="editor-label">
                @Html.LabelFor(model => model.Celular2, "Outro celular")
            </div>
            <div class="editor-field">
                @Html.DisplayFor(model => model.Celular2)
            </div>
        </div>
        <div class="clear"></div>
         <hr />
        <h3>Endereço</h3>
        <br />
        <div class="left">
            <div class="editor-label">
                @Html.LabelFor(model => model.Endereco, "Logradouro")
            </div>
            <div class="editor-field">
                @Html.DisplayFor(model => model.Endereco)
            </div>
        </div>
        <div class="left">
            <div class="editor-label">
                @Html.LabelFor(model => model.CEP)
            </div>
            <div class="editor-field">
                @Html.DisplayFor(model => model.CEP)
            </div>
        </div>
       
        <div class="clear"></div>

        
    </fieldset>

